.rank-container {
  padding: 40rpx;
}
.rank-title {
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  color: #ffd700;
  margin-bottom: 40rpx;
}
.rank-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  border-bottom: 1rpx solid rgba(255,215,0,0.2);
}
.rank-no {
  width: 60rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #ffd700;
}
.rank-name {
  flex: 1;
  font-size: 30rpx;
}
.rank-merit {
  font-size: 28rpx;
  color: #ffd700;
}
.rank-empty {
  text-align: center;
  padding: 80rpx;
  opacity: 0.5;
}
