<view class="rank-container">
  <view class="rank-title">好友功德排行榜</view>
  <view class="rank-list">
    <view class="rank-item" wx:for="{{rankList}}" wx:key="openid">
      <text class="rank-no">{{index + 1}}</text>
      <text class="rank-name">{{item.nickname || '匿名'}}</text>
      <text class="rank-merit">{{item.merit}} 功德</text>
    </view>
    <view wx:if="{{!rankList.length}}" class="rank-empty">暂无排行数据</view>
  </view>
</view>
