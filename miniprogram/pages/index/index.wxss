.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  min-height: 100vh;
}
.merit-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}
.merit-label {
  font-size: 32rpx;
  opacity: 0.7;
}
.merit-value {
  font-size: 80rpx;
  font-weight: bold;
  color: #ffd700;
}
.combo-area {
  margin-bottom: 20rpx;
}
.combo-text {
  font-size: 36rpx;
  color: #ff6347;
  font-weight: bold;
}
.fish-area {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.fish-img {
  width: 300rpx;
  height: 300rpx;
  transition: transform 0.08s;
}
.fish-tap {
  transform: scale(0.9);
}
.float-text {
  position: absolute;
  top: 40rpx;
  font-size: 36rpx;
  color: #ffd700;
  font-weight: bold;
  opacity: 0;
  pointer-events: none;
}
.float-up {
  animation: floatUp 0.8s ease-out forwards;
}
@keyframes floatUp {
  0% { opacity: 1; transform: translateY(0); }
  100% { opacity: 0; transform: translateY(-120rpx); }
}
.effect-ring {
  position: absolute;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  pointer-events: none;
}
.combo10 {
  border: 4rpx solid #ffd700;
  animation: pulse 0.6s infinite;
}
.combo50 {
  border: 6rpx solid #ff69b4;
  box-shadow: 0 0 30rpx #ff69b4;
  animation: pulse 0.4s infinite;
}
.combo100 {
  border: 8rpx solid #ffd700;
  box-shadow: 0 0 60rpx #ffd700, 0 0 120rpx #ff4500;
  animation: pulse 0.3s infinite;
}
@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.08); opacity: 0.7; }
}
.bottom-bar {
  position: fixed;
  bottom: 60rpx;
  display: flex;
  gap: 40rpx;
}
.btn {
  padding: 16rpx 40rpx;
  background: rgba(255,215,0,0.15);
  border: 2rpx solid #ffd700;
  border-radius: 40rpx;
  color: #ffd700;
  font-size: 28rpx;
}
.share-btn {
  background: rgba(255,215,0,0.15) !important;
  line-height: normal;
  font-size: 28rpx !important;
}
